{
    "name": "litebans-rest",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "db:generate": "prisma migrate dev",
        "db:migrate": "prisma migrate deploy",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:dev": "docker-compose -f 'dev-db/docker-compose.yml' up -d",
        "start": "bun run src/index.ts",
        "dev": "bun run src/index.ts --watch",
        "vercel-build": "prisma generate --schema prisma/schema.prisma && bun build src/vercel.ts --outfile api/index.js --target node --format esm --external @scalar/fastify-api-reference"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/pg": "^8.18.0",
        "prisma": "^7.4.2"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@fastify/swagger": "^9.7.0",
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@scalar/fastify-api-reference": "^1.48.0",
        "fastify": "^5.8.2",
        "pg": "^8.20.0",
        "zod": "^4.3.6"
    }
}
